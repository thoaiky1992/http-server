{
  "name": "@thoaiky1992/http-server",
  "version": "1.0.0",
  "main": "dist/index",
  "types": "dist/index",
  "author": "Thoại Kỳ",
  "scripts": {
    "copy-files": "copyfiles --all --up 1 --exclude \"./**/*.{ts,tsx,js}\" \"./src/**/*\" ./dist",
    "build:tsc": "rimraf dist && tsc && tsc-alias && npm run copy-files",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "prettier": "prettier --check src",
    "prettier:fix": "prettier --write src"
  },
  "files": ["dist"],
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "{src,test}/**/*.{js,ts}": [
      "eslint --fix",
      "prettier --write -u"
    ]
  },
  "keywords": [],
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "copyfiles": "^2.4.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/lodash": "^4.17.6",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.14.15",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^4.3.8",
    "lint-staged": "^12.3.3",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "http": "^0.0.1-security",
    "http-status-codes": "^2.3.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "multer": "^1.4.5-lts.1",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.8.0",
    "uuid": "^10.0.0",
    "winston": "^3.13.1",
  }
}
