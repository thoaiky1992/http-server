{
  "name": "@thoaiky1992/http-server",
  "version": "1.1.30",
  "main": "dist/index",
  "types": "dist/index",
  "author": "Thoại Kỳ",
  "description": "The package simplifies creating RESTful APIs in TypeScript with decorators, enabling automatic handling of routes, request parameters, and validations. It is built on top of Express.js, leveraging its capabilities while adding higher-level abstractions for easier API development",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thoaiky1992/http-server.git"
  },
  "scripts": {
    "copy-files": "copyfiles --all --up 1 --exclude \"./**/*.{ts,tsx,js}\" \"./src/**/*\" ./dist",
    "build": "rimraf dist && tsc && tsc-alias && npm run copy-files",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "prettier": "prettier --check src",
    "prettier:fix": "prettier --write src"
  },
  "files": [
    "dist"
  ],
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "{src,test}/**/*.{js,ts}": [
      "eslint --fix",
      "prettier --write -u"
    ]
  },
  "keywords": [
    "http-server",
    "thoaiky1992",
    "http",
    "server",
    "thoaiky",
    "decorator",
    "typescript"
  ],
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.14.15",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "copyfiles": "^2.4.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^4.3.8",
    "lint-staged": "^12.3.3",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "http": "^0.0.1-security",
    "http-status-codes": "^2.3.0",
    "moment": "^2.30.1",
    "multer": "^1.4.5-lts.1",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.8.0",
    "winston": "^3.13.1"
  }
}
